# Copy to .env and replace every /volume1/... example.
# Do not commit .env or any file under secrets/.

NAS_UID=1000
NAS_GID=1000

HERMES_SSH_TARGET=anton@192.168.1.20
SSH_PORT=22
NAS_SOURCE_IP=192.168.1.10
HERMES_EXPORTER_PATH=/home/anton/.local/bin/hermes-backup-stream
RESTIC_HOST=hermes-server
RESTIC_TAG=hermes

RESTIC_REPOSITORY_PATH=/volume1/Backups/restic-hermes
SSH_PRIVATE_KEY_PATH=/volume1/docker/hermes-backup/secrets/hermes_ed25519
SSH_KNOWN_HOSTS_PATH=/volume1/docker/hermes-backup/secrets/known_hosts
RESTIC_PASSWORD_PATH=/volume1/docker/hermes-backup/secrets/restic_password

FORGET_AFTER_BACKUP=true
PRUNE_AFTER_BACKUP=false
KEEP_DAILY=7
KEEP_WEEKLY=5
KEEP_MONTHLY=12
